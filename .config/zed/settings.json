// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "icon_theme": "Catppuccin Macchiato",
  "git_panel": {
    "tree_view": true,
  },
  "show_edit_predictions": true,
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
    "enabled_in_text_threads": false,
  },
  "vim_mode": true,
  "agent": {
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-opus-4-6",
    },
    "default_profile": "ask",
    "dock": "right",
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-5",
    },
    "model_parameters": [],
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark Pro Max",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "relative_line_numbers": "enabled",
  "ui_font_size": 16,
  "buffer_font_size": null,
  "buffer_font_features": {
    "calt": false,
  },
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_file_finder": false,
  },
  "journal": {
    "hour_format": "hour24",
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": false,
    "show_parameter_hints": true,
    "show_other_hints": true,
  },
  "context_servers": {
    "mcp-server-linear": {
      "enabled": true,
      "settings": {},
    },
    "mcp-server-context7": {
      "enabled": false,
      "settings": {
        "default_minimum_tokens": "10000",
      },
    },
    "storyblok": {
      "enabled": false,
      "command": "/Users/emilnordling/source/mcp-server-sb/mcp-server",
      "args": [],
      "env": {},
    },
    "container-use-mcp": {
      "enabled": true,
      "settings": {},
    },
    "linear": {
      "enabled": true,
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.linear.app/sse"],
      "env": {},
      "settings": {},
    },
  },
  // "language_servers": [
  //   "vtsls",
  //   "!typescript-language-server",
  //   "eslint",
  //   "!biome",
  //   "tailwindcss-language-server",
  //   "..."
  // ],
  "lsp": {
    "vtsls": {
      "settings": {
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "tsserver": {
            "maxTsServerMemory": 16184,
          },
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": false,
            },
            "parameterTypes": {
              "enabled": true,
            },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true,
            },
            "propertyDeclarationTypes": {
              "enabled": true,
            },
            "functionLikeReturnTypes": {
              "enabled": true,
            },
            "enumMemberValues": {
              "enabled": true,
            },
          },
        },
      },
      // "language_ids": [
      //   "typescript",
      //   "javascript",
      //   "typescriptreact",
      //   "javascriptreact"
      // ]
    },
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
        },
      },
    },
  },
  "languages": {
    "Rust": {
      "inlay_hints": {
        "show_background": true,
        "show_type_hints": true,
      },
    },
    "Go": {
      "formatter": {
        "external": {
          "command": "goimports",
          "arguments": [],
        },
      },
      "code_actions_on_format": {},
      "format_on_save": "on",
    },
    "JavaScript": {
      "format_on_save": "on",
      "show_edit_predictions": true,
    },
    "TSX": {
      "show_edit_predictions": true,
      "format_on_save": "on",
    },
    "TypeScript": {
      "show_edit_predictions": true,
      "format_on_save": "on",
    },
  },
  "project_panel": {
    "file_icons": true,
  },
}
